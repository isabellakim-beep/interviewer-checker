# ─── Google Calendar (Service Account) ───────────────────────────────────────
# Download the JSON key file from Google Cloud Console → IAM → Service Accounts
# Then share your Google Calendar with the service account email
GOOGLE_SERVICE_ACCOUNT_EMAIL=your-service-account@your-project.iam.gserviceaccount.com
GOOGLE_PRIVATE_KEY="-----BEGIN RSA PRIVATE KEY-----\n...\n-----END RSA PRIVATE KEY-----"
GOOGLE_CALENDAR_ID=your-email@domain.com   # The calendar to monitor

# ─── Zoom (Server-to-Server OAuth) ───────────────────────────────────────────
# Create a Server-to-Server OAuth app at marketplace.zoom.us
# Required scopes: dashboard_meetings:read:admin
ZOOM_ACCOUNT_ID=your_account_id
ZOOM_CLIENT_ID=your_client_id
ZOOM_CLIENT_SECRET=your_client_secret

# ─── Slack ────────────────────────────────────────────────────────────────────
# Create a Slack app at api.slack.com/apps
# Required scopes: chat:write, users:read.email, im:write
SLACK_BOT_TOKEN=xoxb-your-bot-token

# ─── You (the organizer) ─────────────────────────────────────────────────────
MY_EMAIL=your-email@domain.com         # To exclude you from interviewer detection
MY_SLACK_USER_ID=U0123456789           # Your Slack user ID for alert DMs

# ─── Greenhouse ──────────────────────────────────────────────────────────────
GREENHOUSE_EMAIL_DOMAIN=greenhouse.io  # Used to exclude Greenhouse from attendees

# ─── Security ─────────────────────────────────────────────────────────────────
# Vercel automatically adds CRON_SECRET — used to protect the endpoint
CRON_SECRET=generate-a-random-secret-here
